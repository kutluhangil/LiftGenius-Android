# Release signing config for LiftGenius (Play Store).
# Copy this file to `keystore.properties` (gitignored) and fill in real values.
# Generate a keystore first:
#   keytool -genkey -v -keystore liftgenius-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias liftgenius
#
# storeFile is resolved relative to the repo root.
storeFile=liftgenius-release.jks
storePassword=CHANGE_ME
keyAlias=liftgenius
keyPassword=CHANGE_ME
