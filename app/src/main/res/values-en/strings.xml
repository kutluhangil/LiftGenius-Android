    <string name="help_title">Help &amp; Support</string>
    <string name="help_headline">How can we help you?</string>
    <string name="help_desc">Browse frequently asked questions or write to us directly; we\'ll get back to you as soon as we can.</string>
    <string name="help_faq">FREQUENTLY ASKED QUESTIONS</string>
    <string name="help_still">STILL NEED HELP?</string>
    <string name="help_email_support">Get Email Support</string>
    <string name="faq_q1">How do I add a client?</string>
    <string name="faq_a1">Tap the + button on the Clients tab, enter the basic info and save.</string>
    <string name="faq_q2">How do I track packages and sessions?</string>
    <string name="faq_a2">You can add packages on the client detail and schedule sessions from the Calendar tab.</string>
    <string name="faq_q3">How do I mark payments?</string>
    <string name="faq_a3">Turn on the \"Paid\" switch while adding or editing a package.</string>
    <string name="faq_q4">How do I change the app language?</string>
    <string name="faq_a4">Tap the Language row on the Profile tab to switch between Turkish and English.</string>
    <string name="faq_q5">Is my data safe?</string>
    <string name="faq_a5">Data is transmitted over an encrypted connection and stored privately under your account.</string>

    <!-- Privacy -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_intro">Your privacy matters to us. Below we summarize what data we collect and why.</string>
    <string name="privacy_s1_title">Data We Collect</string>
    <string name="privacy_s1_body">To create your account we collect your email address and name; while you use the app we store the client records you enter (name, phone, measurements, session and payment info). This data is used only to run the app.</string>
    <string name="privacy_s2_title">Use of Data</string>
    <string name="privacy_s2_body">Your data is tied to your private account and processed only to provide client-management features. It is not used for advertising or marketing.</string>
    <string name="privacy_s3_title">Sharing &amp; Tracking</string>
    <string name="privacy_s3_body">Your data is not shared with ad networks or third parties for marketing. The app contains no ad tracking.</string>
    <string name="privacy_s4_title">Security</string>
    <string name="privacy_s4_body">Data is transmitted over encrypted connections and access to your account is protected with authentication.</string>
    <string name="privacy_s5_title">Your Rights</string>
    <string name="privacy_s5_body">You can request deletion of all data belonging to your account. To do so, email us via Help &amp; Support.</string>
